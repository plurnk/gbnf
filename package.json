{
  "name": "@plurnk/gbnf",
  "version": "0.1.1",
  "description": "A Node-native, zero-dependency GBNF grammar validator",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=25"
  },
  "bin": {
    "gbnf": "./dist/bin/gbnf.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plurnk/gbnf.git"
  },
  "bugs": "https://github.com/plurnk/gbnf/issues",
  "homepage": "https://github.com/plurnk/gbnf#readme",
  "keywords": [
    "gbnf",
    "grammar",
    "bnf",
    "ebnf",
    "llama.cpp",
    "validator",
    "constrained-generation"
  ],
  "scripts": {
    "build:fetchLlamaGrammar": "scripts/fetchLlamaGrammar.sh",
    "build:llama": "scripts/buildLlama.sh",
    "build": "npm run build:fetchLlamaGrammar && npm run build:llama",
    "build:dist": "rm -rf dist && tsc -p tsconfig.build.json",
    "test:lint": "tsc --noEmit",
    "test:intg": "node --test test/intg/*.test.ts",
    "test:e2e": "node --test test/e2e/*.test.ts",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include='src/**' --test-coverage-lines=50 --test-coverage-branches=50 --test-coverage-functions=50 test/intg/*.test.ts",
    "test:all": "npm run test:lint && npm run test:coverage && npm run test:e2e",
    "prepublishOnly": "npm run test:lint && npm run test:intg && npm run build:dist"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
